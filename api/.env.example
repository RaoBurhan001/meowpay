# Copy to .env — sensible defaults already work for local dev.
PORT=3001
# SQLite database file (created automatically on first run).
DATABASE_PATH=meowpay.sqlite
# Secret used to sign JWTs. Change in any real deployment.
JWT_SECRET=dev-super-secret-change-me
JWT_EXPIRES_IN=1d
# Treats granted to a new wallet on registration (demo convenience — human
# top-up is out of scope for this slice).
STARTING_BALANCE=100
# Comma-separated origins allowed by CORS (the Next.js dev server).
CORS_ORIGIN=http://localhost:3000
